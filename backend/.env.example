# ---- Google Gemini / ADK ----
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ADK uses Google AI Studio (not Vertex) when this is FALSE.
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Model used by every ADK agent
GEMINI_MODEL=gemini-2.5-flash

# Embedding model for RAG retrieval (JSON MVP -> Vertex Vector Search later)
EMBEDDING_MODEL=text-embedding-004

# How many schemes the recommendation agent returns
RAG_TOP_K=8

# ---- Flask ----
FLASK_PORT=8080
FLASK_DEBUG=1
